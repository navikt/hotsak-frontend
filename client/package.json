  "scripts": {
    "dev": "vite",
    "tsc": "tsc -b",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest --dir ./src",
    "test:ci": "vitest --run --dir ./src",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "codegen:grunndata": "graphql-codegen --config grunndata-codegen.yaml",
