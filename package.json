{
  "name": "hotsak-frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5"
  },
  "scripts": {
    "build:client": "pnpm --prefix client run build",
    "build:server": "go build -C server ./...",
    "build": "npm-run-all build:*",
    "test:client": "pnpm --prefix client run test:ci",
    "test:server": "go test -C server ./...",
    "test": "npm-run-all test:*",
    "dev": "pnpm --prefix client run dev",
    "dev:server": "<read .env> && go run -C ./server .",
    "e2e": "pnpm --prefix client run e2e",
    "e2e:ui": "pnpm --prefix client run e2e:ui",
    "prepare": "husky || true",
    "lint:client": "pnpm --prefix client run lint",
    "lint:server": "go vet -C server ./...",
    "lint": "npm-run-all lint:*"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
